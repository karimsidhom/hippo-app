# Copy to .env.local and fill in. `EXPO_PUBLIC_*` vars are inlined at
# build time and are visible in the shipped bundle — only put public
# identifiers here (never a service-role key or any secret).

EXPO_PUBLIC_API_URL=https://hippomedicine.com
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
