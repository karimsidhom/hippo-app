    "expo-constants": "~17.0.3",
    "expo-crypto": "~14.0.1",
    "expo-dev-client": "~5.0.6",
    "expo-device": "~7.0.1",
    "expo-haptics": "~14.0.0",
    "expo-linking": "~7.0.3",
    "expo-local-authentication": "~15.0.1",
    "expo-notifications": "~0.29.10",
    "expo-router": "~4.0.9",
