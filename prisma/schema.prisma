// Hippo — Prisma Schema
// Provider: Supabase Postgres
// Auth: Supabase Auth (User.id === auth.users.id)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // Pooled (pgbouncer) — runtime
  directUrl = env("DIRECT_URL")     // Direct — migrations only
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  PRO
}

enum UserRoleType {
  RESIDENT
  FELLOW
  STAFF
  ATTENDING
  PROGRAM_DIRECTOR
}

enum AutonomyLevel {
  OBSERVER
  ASSISTANT
  SUPERVISOR_PRESENT
  INDEPENDENT
  TEACHING
}

enum SurgicalApproach {
  OPEN
  LAPAROSCOPIC
  ROBOTIC
  ENDOSCOPIC
  HYBRID
  PERCUTANEOUS
  OTHER
}

enum OutcomeCategory {
  UNCOMPLICATED
  MINOR_COMPLICATION
  MAJOR_COMPLICATION
  REOPERATION
  DEATH
  UNKNOWN
}

enum ComplicationCategory {
  NONE
  BLEEDING
  INFECTION
  ORGAN_INJURY
  ANASTOMOTIC_LEAK
  DVT_PE
  ILEUS
  CONVERSION
  READMISSION
  OTHER
}

enum AgeBin {
  UNDER_18
  AGE_18_30
  AGE_31_45
  AGE_46_60
  AGE_61_75
  OVER_75
  UNKNOWN
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum EpaAchievementLevel {
  NOT_ACHIEVED
  ACHIEVED
}

enum EpaObservationStatus {
  DRAFT
  SUBMITTED
  PENDING_REVIEW
  SIGNED
  RETURNED
}

// ─── Models ───────────────────────────────────────────────────────────────────

// User.id is explicitly set to the Supabase auth UUID on registration.
// No @default — always provided by the auth layer.
model User {
  id        String   @id
  email     String   @unique
  name      String?
  image     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile         Profile?
  dictationStyle  UserDictationStyle?
  caseLogs        CaseLog[]
  scheduledCases  ScheduledCase[]
  milestones      Milestone[]
  personalRecords PersonalRecord[]
  sentFriendReqs  FriendRequest[]      @relation("SentRequests")
  recvFriendReqs  FriendRequest[]      @relation("ReceivedRequests")
  friendsAsUser1  Friendship[]         @relation("User1")
  friendsAsUser2  Friendship[]         @relation("User2")
  feedEvents      FeedEvent[]
  favoriteQuotes  UserFavoriteQuote[]
  quoteHistory    UserQuoteHistory[]
  following       Follow[]             @relation("Following")
  followers       Follow[]             @relation("Followers")
  portfolioCases  PortfolioCase[]
  pearls          Pearl[]
  pearlLikes      PearlLike[]
  pearlSaves      PearlSave[]
  pearlComments   PearlComment[]
  epaObservations  EpaObservation[]
  assessedObservations EpaObservation[] @relation("AssessorObservations")
  auditLogs        AuditLog[]

  @@map("users")
}

// Learned dictation style preferences. One row per user, mutated in place as
// the user corrects drafts. `profile` is the full StyleProfile blob; we keep
// it as JSON rather than a grid of columns because the schema version can
// evolve without a migration and the profile is always read/written whole.
model UserDictationStyle {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile         Json
  schemaVersion   Int      @default(1)
  correctionCount Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("user_dictation_styles")
}

model Profile {
  id                            String       @id @default(cuid())
  userId                        String       @unique
  user                          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleType                      UserRoleType @default(RESIDENT)
  specialty                     String?
  subspecialty                  String?
  institution                   String?
  city                          String?
  trainingCountry               String?      // "US" | "CA" — determines ACGME vs Royal College EPAs
  pgyYear                       Int?
  trainingYearLabel             String?
  publicProfile                 Boolean      @default(false)
  allowFriendRequests           Boolean      @default(true)
  allowLeaderboardParticipation Boolean      @default(true)
  allowBenchmarkSharing         Boolean      @default(true)
  bio                           String?
  onboardingCompleted           Boolean      @default(false)
  acknowledgedShadowRecordAt    DateTime?    // First-use disclosure that Hippo may not be the official training record
  tier                          String       @default("free")
  createdAt                     DateTime     @default(now())
  updatedAt                     DateTime     @updatedAt

  @@map("profiles")
}

model Specialty {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  procedures ProcedureDefinition[]

  @@map("specialties")
}

model ProcedureDefinition {
  id                 String           @id @default(cuid())
  specialtyId        String
  specialty          Specialty        @relation(fields: [specialtyId], references: [id])
  name               String
  category           String
  defaultApproach    SurgicalApproach @default(LAPAROSCOPIC)
  cptCode            String?
  avgDurationMinutes Int?
  difficultyBase     Int              @default(3)
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())

  caseLogs CaseLog[]

  @@unique([specialtyId, name])
  @@map("procedure_definitions")
}

model CaseLog {
  id                      String               @id @default(cuid())
  userId                  String
  user                    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialtyId             String?              // stores the specialty slug — no FK constraint
  procedureDefinitionId   String?
  procedureDefinition     ProcedureDefinition? @relation(fields: [procedureDefinitionId], references: [id])
  procedureName           String
  procedureCategory       String?
  surgicalApproach        SurgicalApproach     @default(LAPAROSCOPIC)
  role                    String
  autonomyLevel           AutonomyLevel        @default(SUPERVISOR_PRESENT)
  difficultyScore         Int                  @default(3)
  operativeDurationMinutes Int?
  consoleTimeMinutes      Int?
  dockingTimeMinutes      Int?
  attendingLabel          String?
  institutionSite         String?
  patientAgeBin           AgeBin               @default(UNKNOWN)
  diagnosisCategory       String?
  outcomeCategory         OutcomeCategory      @default(UNCOMPLICATED)
  complicationCategory    ComplicationCategory @default(NONE)
  conversionOccurred      Boolean              @default(false)
  notes                   String?
  tags                    String[]             @default([])
  reflection              String?
  isPublic                Boolean              @default(false)
  benchmarkOptIn          Boolean              @default(true)
  caseDate                DateTime
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  portfolioCase   PortfolioCase?
  epaObservations EpaObservation[]

  @@index([userId])
  @@index([userId, caseDate(sort: Desc)])
  @@map("case_logs")
}

model Milestone {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  procedureName String?
  value         Int
  achievedAt    DateTime @default(now())
  badgeKey      String

  @@index([userId])
  @@map("milestones")
}

model PersonalRecord {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  procedureName String
  recordType    String
  value         Float
  previousValue Float?
  achievedAt    DateTime @default(now())

  @@index([userId])
  @@map("personal_records")
}

model FriendRequest {
  id         String              @id @default(cuid())
  fromUserId String
  fromUser   User                @relation("SentRequests",    fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User                @relation("ReceivedRequests", fields: [toUserId],   references: [id], onDelete: Cascade)
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())

  @@unique([fromUserId, toUserId])
  @@map("friend_requests")
}

model Friendship {
  id        String   @id @default(cuid())
  user1Id   String
  user1     User     @relation("User1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id   String
  user2     User     @relation("User2", fields: [user2Id], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([user1Id, user2Id])
  @@map("friendships")
}

model FeedEvent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType   String   // MILESTONE | PERSONAL_RECORD | CASE_LOGGED | STREAK
  title       String
  description String?
  isPublic    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("feed_events")
}

// ─── Quote Library ───────────────────────────────────────────────────────────

model Quote {
  id               Int      @id @default(autoincrement())
  quote            String
  shortQuote       String?  @map("short_quote")
  author           String
  era              String
  source           String?
  sourceConfidence String   @default("medium") @map("source_confidence")
  themes           String[]
  category         String
  mood             String
  useCase          String[] @map("use_case")
  isVerified       Boolean  @default(true) @map("is_verified")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  favorites UserFavoriteQuote[]
  history   UserQuoteHistory[]

  @@index([author])
  @@index([category])
  @@index([mood])
  @@map("quotes")
}

model UserFavoriteQuote {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  quoteId     Int      @map("quote_id")
  favoritedAt DateTime @default(now()) @map("favorited_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([userId, quoteId])
  @@index([userId])
  @@index([quoteId])
  @@map("user_favorite_quotes")
}

model UserQuoteHistory {
  id      String   @id @default(cuid())
  userId  String   @map("user_id")
  quoteId Int      @map("quote_id")
  shownAt DateTime @default(now()) @map("shown_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([shownAt(sort: Desc)])
  @@map("user_quote_history")
}

// ─── Scheduled Cases ─────────────────────────────────────────────────────────
// An upcoming OR case that the resident has entered ahead of time.
// Drives the Pre-Op Brief → Post-Op Debrief lifecycle:
//   upcoming → brief → done → debrief → linked to CaseLog.
// Lightweight — only the info needed for a brief. The real data goes
// into CaseLog once the case is done and debriefed.

model ScheduledCase {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  procedureName  String
  attendingLabel String?
  scheduledAt    DateTime
  /// "upcoming" | "done" | "cancelled"
  status         String   @default("upcoming")
  notes          String?
  /// Set when the resident debriefs and a CaseLog is created from this
  /// scheduled case. Null while still upcoming/cancelled.
  caseLogId      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, scheduledAt(sort: Asc)])
  @@map("scheduled_cases")
}

// ─── Follow System ───────────────────────────────────────────────────────────
// Asymmetric follow (like Twitter/Instagram). Users can follow others to see
// their public profile, portfolio, and pearls.

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

// ─── Portfolio Cases ─────────────────────────────────────────────────────────
// A curated public selection from a user's private case log. Contains only
// PHIA-safe fields — user writes a separate public title and description.

model PortfolioCase {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseLogId    String   @unique
  caseLog      CaseLog  @relation(fields: [caseLogId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  isFeatured   Boolean  @default(false)
  isMilestone  Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, displayOrder])
  @@map("portfolio_cases")
}

// ─── Pearls ──────────────────────────────────────────────────────────────────
// De-identified educational snippets. All text is PHIA-scrubbed on save.
// Never linked to a specific patient — only references procedure type.

model Pearl {
  id            String      @id @default(cuid())
  authorId      String
  author        User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  procedureName String
  category      String?
  title         String
  content       String
  tags          String[]    @default([])
  likeCount     Int         @default(0)
  saveCount     Int         @default(0)
  commentCount  Int         @default(0)
  isPublished   Boolean     @default(true)
  postType      String      @default("pearl")   // "pearl" | "case_share" | "research" | "discussion"
  imageUrl      String?                          // Optional image URL (Supabase storage)
  linkUrl       String?                          // For research posts — external URL
  linkedCaseId  String?                          // For case shares — reference to CaseLog
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  likes         PearlLike[]
  saves         PearlSave[]
  comments      PearlComment[]

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
  @@index([procedureName])
  @@map("pearls")
}

model PearlLike {
  id        String   @id @default(cuid())
  pearlId   String
  pearl     Pearl    @relation(fields: [pearlId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([pearlId, userId])
  @@index([userId])
  @@map("pearl_likes")
}

model PearlSave {
  id        String   @id @default(cuid())
  pearlId   String
  pearl     Pearl    @relation(fields: [pearlId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([pearlId, userId])
  @@index([userId])
  @@map("pearl_saves")
}

model PearlComment {
  id        String   @id @default(cuid())
  pearlId   String
  pearl     Pearl    @relation(fields: [pearlId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pearlId, createdAt(sort: Desc)])
  @@index([authorId])
  @@map("pearl_comments")
}

// ─── EPA Observations ────────────────────────────────────────────────────────

model EpaObservation {
  id                String                @id @default(cuid())
  userId            String
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseLogId         String?
  caseLog           CaseLog?              @relation(fields: [caseLogId], references: [id], onDelete: SetNull)

  epaId             String                // e.g. "C1", "F2"
  epaTitle          String                // denormalized for display
  specialtySlug     String
  trainingSystem    String                // "ACGME" or "RCPSC"

  observationDate   DateTime
  setting           String?               // "OR", "Clinic", "Simulation", "Ward"
  complexity        String?               // "Low", "Moderate", "High"
  technique         String?               // Technique used (from EPA techniqueOptions)
  assessorName      String
  assessorRole      String?
  assessorEmail     String?
  // If the attending is a Hippo user, link them directly so the observation
  // appears in their in-app Sign-Off inbox (no token round-trip needed).
  assessorUserId    String?
  assessor          User?                 @relation("AssessorObservations", fields: [assessorUserId], references: [id], onDelete: SetNull)

  achievement       EpaAchievementLevel   @default(NOT_ACHIEVED)
  entrustmentScore  Int?                  // Royal College O-Score (1-5)
  canmedsRatings    Json?                 // CanMEDS milestone ratings per role [{roleId, rating}]
  observationNotes  String?
  strengthsNotes    String?
  improvementNotes  String?
  criteriaRatings   Json?
  safetyConcern     Boolean               @default(false)
  professionalismConcern Boolean          @default(false)
  concernDetails    String?

  status            EpaObservationStatus  @default(DRAFT)
  signedAt          DateTime?
  signedByName      String?
  returnedReason    String?

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  notifications     AttendingNotification[]

  @@index([userId])
  @@index([userId, epaId])
  @@index([userId, status])
  @@index([caseLogId])
  @@index([assessorUserId, status])
  @@map("epa_observations")
}

model AttendingNotification {
  id                String   @id @default(cuid())
  epaObservationId  String
  epaObservation    EpaObservation @relation(fields: [epaObservationId], references: [id], onDelete: Cascade)

  recipientEmail    String
  recipientName     String
  accessToken       String   @unique @default(cuid())

  sentAt            DateTime @default(now())
  viewedAt          DateTime?
  respondedAt       DateTime?
  // Long-lived by default — attendings often sign weeks/months later.
  // Null = never expires (e.g. in-app-only notifications).
  expiresAt         DateTime?
  /// "email" | "in_app" | "push" — how the notification was delivered
  channel           String   @default("email")

  @@index([accessToken])
  @@index([epaObservationId])
  @@map("attending_notifications")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────
// Append-only record of all sensitive reads/writes. Never mutate rows —
// corrections are new rows with `action="audit.correction"` pointing to the
// original. Surfaced to users (their own activity) and to PDs (their residents').
model AuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String?  // Actor — nullable for system events
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   // e.g. "case.create", "case.update", "case.delete", "epa.create", "epa.sign", "export.download", "auth.login", "profile.update", "consent.shadowRecord"
  entityType String   // "CaseLog" | "EpaObservation" | "Profile" | "User" | "Export" | "Auth"
  entityId   String?  // id of affected entity (nullable for auth events)
  before     Json?    // snapshot before change (redacted of PHI-free-text when possible)
  after      Json?    // snapshot after change
  ipAddress  String?
  userAgent  String?
  metadata   Json?    // extra context (reason, source route, correlation id)

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
