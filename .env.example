# ─────────────────────────────────────────────────────────────────────────────
# Hippo — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Public anon key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database (Prisma) ─────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → Database → Connection string

# Pooled connection (Transaction mode, port 6543) — used at runtime
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=15

# Direct connection (port 5432) — used for migrations only
DIRECT_URL=postgresql://postgres.your-project-ref:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe (optional — for Pro subscriptions) ─────────────────────────────────
# Found in: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# ── LLM providers ────────────────────────────────────────────────────────────
#
# RECOMMENDED (free + no-training ToS):
#   1. Create a free account at https://console.groq.com
#   2. Create an API key and paste it below
#   3. Set AI_VENDOR_APPROVED=true — Groq's commercial terms commit to not
#      using your inputs or outputs for training their models.
#
# Groq hosts Llama 3.3 70B Versatile with ~30 RPM / 6k TPM on the free
# developer tier and ~400 tok/sec inference. Plenty for a demo.
GROQ_API_KEY=

# OPTIONAL fallbacks. Do NOT enable AI_VENDOR_APPROVED while using ONLY the
# consumer Gemini free tier — it MAY retain inputs for training. Only set
# GOOGLE_AI_API_KEY if you are using Vertex AI or a paid zero-retention tier.
GOOGLE_AI_API_KEY=
ANTHROPIC_API_KEY=

# ── AI vendor gate ───────────────────────────────────────────────────────────
# Every external LLM call is blocked until this is "true". Only flip on when
# the currently-configured vendor is on the qualifying list in
# src/lib/ai-gate.ts (Groq, Anthropic API, OpenAI ZDR, Vertex AI no-log).
# Setting this to true while using the consumer Gemini free tier is a PHIA
# breach.
#
# For the demo with Groq configured above: set this to "true".
AI_VENDOR_APPROVED=true
